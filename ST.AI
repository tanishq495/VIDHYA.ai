import { useState, useRef, useEffect } from "react";

const SUBJECTS = [
  { id: "math", label: "Mathematics", icon: "📐", color: "#FF6B35" },
  { id: "science", label: "Science", icon: "🔬", color: "#4ECDC4" },
  { id: "english", label: "English", icon: "📖", color: "#45B7D1" },
  { id: "hindi", label: "Hindi", icon: "हि", color: "#96CEB4" },
  { id: "marathi", label: "Marathi", icon: "म", color: "#FFEAA7" },
  { id: "history", label: "History & Civics", icon: "🏛️", color: "#DDA0DD" },
  { id: "geography", label: "Geography", icon: "🌍", color: "#98D8C8" },
  { id: "sst", label: "Social Science", icon: "🌐", color: "#F7DC6F" },
];

const POPULAR_TOPICS = {
  math: ["Quadratic Equations", "Trigonometry", "Coordinate Geometry", "Circles", "Arithmetic Progression"],
  science: ["Chemical Reactions", "Light - Reflection", "Heredity & Evolution", "Electricity", "Carbon Compounds"],
  english: ["Letter Writing", "Grammar - Tenses", "Comprehension Skills", "Essay Writing", "Poetry Analysis"],
  hindi: ["संधि विच्छेद", "समास", "कारक", "रस और अलंकार", "पत्र लेखन"],
  marathi: ["व्याकरण", "निबंध लेखन", "कविता विश्लेषण", "पत्र लेखन", "व्याकरण - उभयान्वयी"],
  history: ["Indian Independence Movement", "French Revolution", "Russian Revolution", "Fundamental Rights", "Preamble of India"],
  geography: ["Natural Resources", "Climate of India", "Agriculture", "Water Resources", "Minerals"],
  sst: ["Globalisation", "Democracy", "Development", "Money and Credit", "Consumer Rights"],
};

const SYSTEM_PROMPT = `You are an expert teacher specialized in Maharashtra State Board Class 10 curriculum (SSC Board). 
You explain topics in a clear, structured way suitable for 15-16 year old Indian students preparing for board exams.

When given a topic, create a detailed VIDEO SCRIPT / EXPLANATION in this format:

🎬 **INTRODUCTION** (Hook the student - 2-3 sentences)
Briefly introduce why this topic matters and what they'll learn.

📚 **WHAT IS [TOPIC]?** (Core Definition)
Clear, simple definition with easy-to-understand language.

🔍 **KEY CONCEPTS** (Explain step by step)
Break down the topic into numbered key points. Use examples from everyday Indian life where possible.

✏️ **SOLVED EXAMPLE** (Board Exam Style)
Give a typical board exam question and solve it step by step with all working shown.

💡 **TRICKS & MNEMONICS**
Give memory tricks, shortcuts, or tips that help remember this concept during exams.

⭐ **IMPORTANT FOR BOARD EXAM**
List 2-3 points that frequently appear in Maharashtra board exams with marks weightage if known.

🔁 **QUICK RECAP**
3-4 bullet points summarizing what was covered.

❓ **PRACTICE QUESTIONS** (For self-assessment)
Give 3 practice questions of varying difficulty (Easy / Medium / Hard) with marks like board exam.

Use simple English mixed with Hindi/Marathi terms where helpful. Be encouraging and positive in tone. Format clearly with emojis and bold headings.`;

// ─────────── Animated Typing Component ───────────
function TypedText({ text }) {
  const [displayed, setDisplayed] = useState("");
  const idx = useRef(0);

  useEffect(() => {
    setDisplayed("");
    idx.current = 0;
    if (!text) return;
    const id = setInterval(() => {
      setDisplayed(text.slice(0, idx.current + 1));
      idx.current++;
      if (idx.current >= text.length) clearInterval(id);
    }, 8);
    return () => clearInterval(id);
  }, [text]);

  return <span>{displayed}</span>;
}

// ─────────── Format markdown-like text ───────────
function FormatContent({ content }) {
  if (!content) return null;
  const lines = content.split("\n");
  return (
    <div style={{ lineHeight: 1.8 }}>
      {lines.map((line, i) => {
        if (!line.trim()) return <br key={i} />;
        // Bold headers with **text**
        const boldified = line.replace(/\*\*(.*?)\*\*/g, (_, m) => `<strong>${m}</strong>`);
        // Numbered list
        if (/^\d+\./.test(line.trim())) {
          return (
            <div key={i} style={{ margin: "6px 0 6px 16px", display: "flex", gap: 8 }}>
              <span dangerouslySetInnerHTML={{ __html: boldified }} />
            </div>
          );
        }
        // Bullet
        if (line.trim().startsWith("- ") || line.trim().startsWith("• ")) {
          return (
            <div key={i} style={{ margin: "4px 0 4px 16px", display: "flex", gap: 8 }}>
              <span style={{ color: "#FF6B35" }}>•</span>
              <span dangerouslySetInnerHTML={{ __html: boldified.replace(/^[-•]\s/, "") }} />
            </div>
          );
        }
        // Section header (emoji lines)
        if (/^[🎬📚🔍✏️💡⭐🔁❓]/.test(line.trim())) {
          return (
            <div key={i} style={{
              margin: "20px 0 8px",
              padding: "10px 16px",
              background: "linear-gradient(90deg, rgba(255,107,53,0.15) 0%, transparent 100%)",
              borderLeft: "3px solid #FF6B35",
              borderRadius: "0 8px 8px 0",
              fontWeight: 700,
              fontSize: 16,
              color: "#1a1a2e",
            }}>
              <span dangerouslySetInnerHTML={{ __html: boldified }} />
            </div>
          );
        }
        return (
          <p key={i} style={{ margin: "4px 0" }}>
            <span dangerouslySetInnerHTML={{ __html: boldified }} />
          </p>
        );
      })}
    </div>
  );
}

// ─────────── Video Player Mock ───────────
function VideoPlayer({ topic, subject, content, isLoading }) {
  const [tab, setTab] = useState("video");

  const sectionColors = {
    math: "#FF6B35", science: "#4ECDC4", english: "#45B7D1",
    hindi: "#96CEB4", marathi: "#FFEAA7", history: "#DDA0DD",
    geography: "#98D8C8", sst: "#F7DC6F"
  };
  const accent = sectionColors[subject] || "#FF6B35";

  return (
    <div style={{
      background: "#fff",
      borderRadius: 20,
      overflow: "hidden",
      boxShadow: "0 8px 40px rgba(0,0,0,0.12)",
      border: `1px solid rgba(0,0,0,0.06)`
    }}>
      {/* Video Screen */}
      <div style={{
        background: isLoading
          ? "linear-gradient(135deg, #1a1a2e, #16213e)"
          : `linear-gradient(135deg, #1a1a2e, #16213e)`,
        minHeight: 280,
        display: "flex",
        flexDirection: "column",
        alignItems: "center",
        justifyContent: "center",
        padding: 32,
        position: "relative",
        overflow: "hidden"
      }}>
        {/* Grid overlay */}
        <div style={{
          position: "absolute", inset: 0,
          backgroundImage: "linear-gradient(rgba(255,107,53,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,107,53,0.05) 1px, transparent 1px)",
          backgroundSize: "40px 40px"
        }} />

        {isLoading ? (
          <div style={{ textAlign: "center", zIndex: 1 }}>
            <div style={{
              width: 80, height: 80, borderRadius: "50%",
              border: `4px solid ${accent}`,
              borderTopColor: "transparent",
              animation: "spin 1s linear infinite",
              margin: "0 auto 20px"
            }} />
            <div style={{ color: "#fff", fontSize: 18, fontWeight: 600 }}>
              Generating explanation video...
            </div>
            <div style={{ color: "rgba(255,255,255,0.5)", fontSize: 14, marginTop: 8 }}>
              AI is preparing your lesson on <em>{topic}</em>
            </div>
          </div>
        ) : content ? (
          <div style={{ textAlign: "center", zIndex: 1 }}>
            <div style={{
              width: 90, height: 90, borderRadius: "50%",
              background: `linear-gradient(135deg, ${accent}, ${accent}88)`,
              display: "flex", alignItems: "center", justifyContent: "center",
              fontSize: 40, margin: "0 auto 16px",
              boxShadow: `0 0 40px ${accent}66`
            }}>
              🎬
            </div>
            <div style={{ color: "#fff", fontSize: 22, fontWeight: 700 }}>{topic}</div>
            <div style={{
              color: accent, fontSize: 13, marginTop: 8, fontWeight: 600,
              letterSpacing: 2, textTransform: "uppercase"
            }}>
              Maharashtra Board • Class 10
            </div>
            <div style={{
              marginTop: 20, display: "flex", gap: 12, justifyContent: "center", flexWrap: "wrap"
            }}>
              {["📺 Watch", "🔊 Audio", "📋 Notes"].map(b => (
                <button key={b} style={{
                  background: "rgba(255,255,255,0.1)",
                  border: `1px solid ${accent}44`,
                  color: "#fff", borderRadius: 20, padding: "8px 18px",
                  fontSize: 13, cursor: "pointer", backdropFilter: "blur(10px)"
                }}>{b}</button>
              ))}
            </div>
          </div>
        ) : (
          <div style={{ textAlign: "center", zIndex: 1 }}>
            <div style={{ fontSize: 60, marginBottom: 16 }}>🎓</div>
            <div style={{ color: "rgba(255,255,255,0.6)", fontSize: 16 }}>
              Enter a topic to generate your video lesson
            </div>
          </div>
        )}
      </div>

      {/* Tabs */}
      {content && (
        <>
          <div style={{ display: "flex", borderBottom: "1px solid #f0f0f0" }}>
            {["video", "notes", "practice"].map(t => (
              <button key={t} onClick={() => setTab(t)} style={{
                flex: 1, padding: "14px 0", border: "none",
                background: tab === t ? "#fff" : "#fafafa",
                borderBottom: tab === t ? `2px solid ${accent}` : "2px solid transparent",
                color: tab === t ? accent : "#888",
                fontWeight: tab === t ? 700 : 400,
                fontSize: 14, cursor: "pointer",
                textTransform: "capitalize", letterSpacing: 0.5
              }}>
                {t === "video" ? "📺 Explanation" : t === "notes" ? "📝 Notes" : "✏️ Practice"}
              </button>
            ))}
          </div>

          <div style={{ padding: 24, maxHeight: 500, overflowY: "auto" }}>
            {tab === "video" && <FormatContent content={content} />}
            {tab === "notes" && (
              <div>
                <div style={{
                  background: `linear-gradient(135deg, ${accent}15, ${accent}05)`,
                  border: `1px solid ${accent}30`,
                  borderRadius: 12, padding: 20, marginBottom: 16
                }}>
                  <div style={{ fontWeight: 700, color: accent, marginBottom: 8 }}>📌 Quick Notes — {topic}</div>
                  <div style={{ fontSize: 13, color: "#555" }}>
                    Key points extracted from your lesson. Download or copy for revision.
                  </div>
                </div>
                <FormatContent content={content} />
              </div>
            )}
            {tab === "practice" && (
              <div>
                <div style={{
                  background: "linear-gradient(135deg, #667eea15, #764ba215)",
                  border: "1px solid #667eea30",
                  borderRadius: 12, padding: 20, marginBottom: 16
                }}>
                  <div style={{ fontWeight: 700, color: "#667eea", marginBottom: 4 }}>
                    🏆 Board Exam Practice Mode
                  </div>
                  <div style={{ fontSize: 13, color: "#555" }}>
                    Practice questions are included in the explanation below. Attempt them before checking solutions!
                  </div>
                </div>
                <FormatContent content={content} />
              </div>
            )}
          </div>
        </>
      )}
    </div>
  );
}

// ─────────── Main App ───────────
export default function App() {
  const [selectedSubject, setSelectedSubject] = useState("math");
  const [topic, setTopic] = useState("");
  const [content, setContent] = useState(null);
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState(null);
  const [history, setHistory] = useState([]);
  const inputRef = useRef();

  const subjectData = SUBJECTS.find(s => s.id === selectedSubject);
  const accent = subjectData?.color || "#FF6B35";

  async function generateExplanation(topicToSearch) {
    const t = topicToSearch || topic.trim();
    if (!t) return;
    setIsLoading(true);
    setError(null);
    setContent(null);

    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-6",
          max_tokens: 1000,
          system: SYSTEM_PROMPT,
          messages: [{
            role: "user",
            content: `Subject: ${subjectData?.label}\nTopic: ${t}\n\nPlease create a detailed explanation video script for this topic for Maharashtra Board Class 10 students.`
          }]
        })
      });

      const data = await response.json();
      if (data.error) throw new Error(data.error.message);
      
      const text = data.content?.map(b => b.text || "").join("\n") || "";
      setContent(text);
      setHistory(prev => [{ topic: t, subject: selectedSubject, time: new Date().toLocaleTimeString() }, ...prev.slice(0, 9)]);
      if (!topicToSearch) setTopic("");
    } catch (err) {
      setError("Failed to generate explanation. Please try again.");
    } finally {
      setIsLoading(false);
    }
  }

  return (
    <div style={{
      minHeight: "100vh",
      background: "linear-gradient(135deg, #0f0c29, #302b63, #24243e)",
      fontFamily: "'Segoe UI', system-ui, sans-serif",
      padding: "0 0 60px"
    }}>
      <style>{`
        @keyframes spin { to { transform: rotate(360deg); } }
        @keyframes fadeIn { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
        * { box-sizing: border-box; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #FF6B3544; border-radius: 3px; }
      `}</style>

      {/* Header */}
      <div style={{
        background: "rgba(255,255,255,0.04)",
        backdropFilter: "blur(20px)",
        borderBottom: "1px solid rgba(255,255,255,0.08)",
        padding: "16px 24px",
        display: "flex", alignItems: "center", justifyContent: "space-between",
        position: "sticky", top: 0, zIndex: 100
      }}>
        <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
          <div style={{
            width: 44, height: 44, borderRadius: 12,
            background: "linear-gradient(135deg, #FF6B35, #FF8C5A)",
            display: "flex", alignItems: "center", justifyContent: "center",
            fontSize: 22, boxShadow: "0 4px 15px #FF6B3555"
          }}>🎓</div>
          <div>
            <div style={{ color: "#fff", fontWeight: 800, fontSize: 18 }}>VidyaAI</div>
            <div style={{ color: "rgba(255,255,255,0.45)", fontSize: 11, letterSpacing: 1 }}>
              MAHARASHTRA BOARD • CLASS 10
            </div>
          </div>
        </div>
        <div style={{
          background: "rgba(255,107,53,0.15)",
          border: "1px solid rgba(255,107,53,0.3)",
          color: "#FF6B35", borderRadius: 20,
          padding: "6px 14px", fontSize: 12, fontWeight: 600
        }}>
          SSC 2025–26
        </div>
      </div>

      <div style={{ maxWidth: 1100, margin: "0 auto", padding: "28px 20px" }}>
        
        {/* Hero */}
        <div style={{ textAlign: "center", marginBottom: 36 }}>
          <h1 style={{
            color: "#fff", fontSize: "clamp(24px, 4vw, 38px)",
            fontWeight: 800, margin: "0 0 10px",
            background: "linear-gradient(135deg, #fff, #FF6B35)",
            WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent"
          }}>
            AI Video Explanations for Class 10
          </h1>
          <p style={{ color: "rgba(255,255,255,0.5)", margin: 0, fontSize: 16 }}>
            Pick your subject → Enter any topic → Get a complete board-exam ready lesson
          </p>
        </div>

        {/* Subject Selector */}
        <div style={{
          display: "grid",
          gridTemplateColumns: "repeat(auto-fit, minmax(110px, 1fr))",
          gap: 10, marginBottom: 28
        }}>
          {SUBJECTS.map(s => (
            <button key={s.id} onClick={() => {
              setSelectedSubject(s.id);
              setContent(null);
              setTopic("");
            }} style={{
              padding: "12px 8px",
              borderRadius: 14,
              border: selectedSubject === s.id
                ? `2px solid ${s.color}`
                : "2px solid rgba(255,255,255,0.08)",
              background: selectedSubject === s.id
                ? `${s.color}22`
                : "rgba(255,255,255,0.04)",
              color: selectedSubject === s.id ? s.color : "rgba(255,255,255,0.6)",
              cursor: "pointer",
              textAlign: "center",
              fontWeight: selectedSubject === s.id ? 700 : 500,
              fontSize: 13,
              transition: "all 0.2s",
              backdropFilter: "blur(10px)"
            }}>
              <div style={{ fontSize: 22, marginBottom: 5 }}>{s.icon}</div>
              {s.label}
            </button>
          ))}
        </div>

        {/* Search Bar */}
        <div style={{
          background: "rgba(255,255,255,0.06)",
          border: `2px solid ${accent}44`,
          borderRadius: 20, padding: "6px 6px 6px 20px",
          display: "flex", gap: 10, alignItems: "center",
          marginBottom: 20, backdropFilter: "blur(20px)",
          boxShadow: `0 0 40px ${accent}22`
        }}>
          <span style={{ fontSize: 20 }}>🔍</span>
          <input
            ref={inputRef}
            value={topic}
            onChange={e => setTopic(e.target.value)}
            onKeyDown={e => e.key === "Enter" && generateExplanation()}
            placeholder={`Enter any ${subjectData?.label} topic... e.g. "${POPULAR_TOPICS[selectedSubject]?.[0]}"`}
            style={{
              flex: 1, background: "transparent", border: "none",
              outline: "none", color: "#fff", fontSize: 16,
              "::placeholder": { color: "rgba(255,255,255,0.3)" }
            }}
          />
          <button
            onClick={() => generateExplanation()}
            disabled={isLoading || !topic.trim()}
            style={{
              background: isLoading || !topic.trim()
                ? "rgba(255,255,255,0.1)"
                : `linear-gradient(135deg, ${accent}, ${accent}cc)`,
              border: "none", color: "#fff",
              padding: "12px 24px", borderRadius: 14,
              fontWeight: 700, fontSize: 15, cursor: isLoading ? "wait" : "pointer",
              transition: "all 0.2s",
              boxShadow: !isLoading && topic.trim() ? `0 4px 20px ${accent}55` : "none"
            }}
          >
            {isLoading ? "⏳ Generating..." : "🎬 Generate Video"}
          </button>
        </div>

        {/* Popular Topics */}
        <div style={{ marginBottom: 28 }}>
          <div style={{ color: "rgba(255,255,255,0.4)", fontSize: 12, marginBottom: 10, letterSpacing: 1 }}>
            POPULAR TOPICS IN {subjectData?.label.toUpperCase()}
          </div>
          <div style={{ display: "flex", flexWrap: "wrap", gap: 8 }}>
            {POPULAR_TOPICS[selectedSubject]?.map(t => (
              <button key={t} onClick={() => {
                setTopic(t);
                generateExplanation(t);
              }} style={{
                background: "rgba(255,255,255,0.06)",
                border: `1px solid ${accent}33`,
                color: "rgba(255,255,255,0.7)",
                borderRadius: 20, padding: "6px 14px",
                fontSize: 13, cursor: "pointer",
                transition: "all 0.2s"
              }}>
                {t}
              </button>
            ))}
          </div>
        </div>

     
